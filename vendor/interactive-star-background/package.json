{
  "name": "interactive-star-background",
  "version": "1.0.0",
  "description": "Zero-dependency React component: fullscreen canvas starfield with twinkling stars, spring-physics particles, drifting orbs, and cursor-reactive glow.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./src": "./src/index.js",
    "./src/ParticleBackground.jsx": "./src/ParticleBackground.jsx"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "canvas",
    "background",
    "particles",
    "stars",
    "starfield",
    "interactive",
    "animation"
  ],
  "author": "24node Solutions INC.",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "demo": "npx --yes serve ."
  }
}
